let currentLang = "en";

function toggleLanguage() {

const html = document.documentElement;
const button = document.querySelector(".lang-btn");

if(currentLang === "en"){

currentLang = "ar";

html.lang = "ar";
html.dir = "rtl";

button.textContent = "English";

document.querySelectorAll("[data-ar]").forEach(el => {

el.innerHTML = el.dataset.ar;

});

}else{

currentLang = "en";

html.lang = "en";
html.dir = "ltr";

button.textContent = "العربية";

document.querySelectorAll("[data-en]").forEach(el => {

el.innerHTML = el.dataset.en;

});

}

}

/* NAVBAR SCROLL EFFECT */

window.addEventListener("scroll", ()=>{

const navbar = document.querySelector(".navbar");

if(window.scrollY > 50){

navbar.style.background = "rgba(0,0,0,0.82)";

}else{

navbar.style.background = "rgba(0,0,0,0.45)";

}

});

/* ANIMATIONS */

const observer = new IntersectionObserver((entries)=>{

entries.forEach((entry)=>{

if(entry.isIntersecting){

entry.target.style.opacity = "1";
entry.target.style.transform = "translateY(0px)";

}

});

},{
threshold:0.15
});

document.querySelectorAll(
".service-card,.equipment-card,.projects-grid img,.director-box,.stat-box"
).forEach((el)=>{

el.style.opacity = "0";
el.style.transform = "translateY(40px)";
el.style.transition = "0.7s ease";

observer.observe(el);

});
